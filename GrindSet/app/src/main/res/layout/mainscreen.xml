<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainScreenLogo"
            android:layout_width="170dp"
            android:layout_height="80dp"
            app:cardCornerRadius="10dp"
            app:strokeColor="#000000"
            app:strokeWidth="2dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/grindset_logo_v2"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/naviBtn"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_toEndOf="@id/mainScreenLogo"
            android:layout_alignTop="@id/mainScreenLogo"
            android:src="@drawable/menu"
            android:layout_marginStart="60dp"
            android:layout_marginTop="60dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/welcomeTextView"
            android:layout_below="@id/mainScreenLogo"
            android:layout_marginTop="20dp"
            android:layout_marginStart="10dp"
            android:textSize="40sp"
            android:text="Username Placeholder."
            android:textStyle="bold" />

        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:id="@+id/profileLogo"
            android:src="@drawable/user_logo"
            android:layout_below="@id/welcomeTextView"
            android:layout_marginTop="440dp"
            android:layout_centerInParent="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/profileLogo"
            android:text="Profile"
            android:layout_centerInParent="true"
            android:textStyle="bold"
            android:layout_marginTop="5dp" />
    </RelativeLayout>
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/navigation_menu" />

</androidx.drawerlayout.widget.DrawerLayout>